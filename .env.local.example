# Environment Variables Example
# Copy this file to .env.local and fill in your values

# ============================================================================
# Application Settings
# ============================================================================

# Base URL of your application (used for API routes and image serving)
# Development: Leave empty or use http://localhost:3000
# Production: Set to your domain (e.g., https://yourwedding.com)
NEXT_PUBLIC_BASE_URL=

# ============================================================================
# Google Forms Integration (Optional)
# ============================================================================
# Required only if you want to sync RSVP responses from Google Forms
# See documentation/GOOGLE_FORMS_SETUP.md for setup instructions

# Your Google Cloud service account credentials (JSON format as a single-line string)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project-id","private_key_id":"your-key-id","private_key":"-----BEGIN PRIVATE KEY-----\\nYOUR-PRIVATE-KEY\\n-----END PRIVATE KEY-----\\n","client_email":"your-service-account@your-project.iam.gserviceaccount.com","client_id":"your-client-id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"your-cert-url"}'

# Your Google Sheets spreadsheet ID (from the sheet URL)
# Get this from: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_FORMS_SPREADSHEET_ID=your-spreadsheet-id-here

# ============================================================================
# Image Source Configuration (Optional)
# Choose where to load wedding photos from: local files or Google Drive
# See documentation/IMAGE_SOURCES.md for detailed setup instructions
# ============================================================================

# Image source type: "local" (default), "google-drive", "direct-google-drive", or "hybrid"
# - local: Images from public/images directory (no additional setup needed)
# - google-drive: Images from Google Drive folders via API proxy (requires Node.js server)
# - direct-google-drive: Direct Google Drive URLs (for static sites like GitHub Pages - files must be public)
# - hybrid: Uses both local and Google Drive images (local has priority)
IMAGE_SOURCE_TYPE=local

# Google Drive Configuration (Required if using google-drive or hybrid mode)
# The GOOGLE_SERVICE_ACCOUNT_KEY above is reused for Google Drive access

# Main Google Drive folder ID (parent folder containing all image folders)
# Get this from the folder URL: https://drive.google.com/drive/folders/[FOLDER_ID]
GOOGLE_DRIVE_FOLDER_ID=your-main-folder-id

# Individual folder IDs for each image collection (Optional)
# If not specified, the system will look for subfolders with these names in the main folder
# Folder names to look for: hero-album, gallery, throwback, prenup

# Hero album images (background slideshow on hero section)
GOOGLE_DRIVE_HERO_ALBUM_FOLDER_ID=your-hero-album-folder-id

# Gallery images (photos in the gallery section)
GOOGLE_DRIVE_GALLERY_FOLDER_ID=your-gallery-folder-id

# Throwback photos (old photos in the story section)
GOOGLE_DRIVE_THROWBACK_FOLDER_ID=your-throwback-folder-id

# Prenup photos (engagement/prenup photos in the story section)
GOOGLE_DRIVE_PRENUP_FOLDER_ID=your-prenup-folder-id

# ============================================================================
# Image Cache Configuration (Optional)
# Control how long images from Google Drive are cached
# ============================================================================

# Enable/disable caching for Google Drive images
# Set to "false" to always fetch fresh images (slower but always up-to-date)
# Default: true
IMAGE_CACHE_ENABLED=true

# Cache duration in milliseconds
# Examples: 60000 (1 minute), 300000 (5 minutes), 600000 (10 minutes)
# Default: 300000 (5 minutes)
# Set to 0 to disable caching
IMAGE_CACHE_DURATION=300000

# Optional: Secret token for clearing cache via API
# If set, you must include this as Bearer token when calling /api/cache/clear
# CACHE_CLEAR_SECRET=your-secret-token-here
