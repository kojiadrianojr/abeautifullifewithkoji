# Environment Variables Example
# This file shows all possible environment variables for the wedding website
# Copy this to .env.local for local development

# ============================================================================
# Application Settings
# ============================================================================

# Base URL of your application (used for API routes and image serving)
# Development: Leave empty or use http://localhost:3000
# Production: Set to your domain (e.g., https://yourwedding.com)
NEXT_PUBLIC_BASE_URL=

# Base path for GitHub Pages deployment
# ⚠️ IMPORTANT: Only set this if deploying to a SUBDIRECTORY (e.g., username.github.io/repo-name)
# 
# For CUSTOM DOMAIN (e.g., yourwedding.com or abeautifullifewithkoji.arkea.tech):
#   - Leave EMPTY or UNSET this variable
#   - Example: NEXT_PUBLIC_BASE_PATH=
#
# For SUBDIRECTORY deployment (e.g., username.github.io/abeautifullifewithkoji):
#   - Set to your repository name with leading slash
#   - Example: NEXT_PUBLIC_BASE_PATH=/abeautifullifewithkoji
#
# Development: Always leave empty
NEXT_PUBLIC_BASE_PATH=

# ============================================================================
# Google Forms Integration (Optional)
# ============================================================================
# Required only if you want to sync RSVP responses from Google Forms
# See documentation/GOOGLE_FORMS_SETUP.md for setup instructions

# Your Google Cloud service account credentials (JSON format as a single-line string)
# For GitHub Secrets: Store the entire JSON as a secret named GOOGLE_SERVICE_ACCOUNT_KEY
GOOGLE_SERVICE_ACCOUNT_KEY=

# Your Google Sheets spreadsheet ID (from the sheet URL)
# Get this from: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
# For GitHub Secrets: Store as GOOGLE_FORMS_SPREADSHEET_ID
GOOGLE_FORMS_SPREADSHEET_ID=

# ============================================================================
# Image Source Configuration (Optional)
# ============================================================================

# Image source type: "local" (default), "google-drive", "direct-google-drive", or "hybrid"
# For GitHub Secrets: Store as IMAGE_SOURCE_TYPE
IMAGE_SOURCE_TYPE=local

# Google Drive Configuration (Required if using google-drive or hybrid mode)
# Main Google Drive folder ID (parent folder containing all image folders)
# For GitHub Secrets: Store as GOOGLE_DRIVE_FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=

# Individual folder IDs for each image collection (Optional)
# For GitHub Secrets: Store each as separate secrets
GOOGLE_DRIVE_HERO_ALBUM_FOLDER_ID=
GOOGLE_DRIVE_GALLERY_FOLDER_ID=
GOOGLE_DRIVE_THROWBACK_FOLDER_ID=
GOOGLE_DRIVE_PRENUP_FOLDER_ID=

# ============================================================================
# Image Cache Configuration (Optional)
# ============================================================================

# Enable/disable caching for Google Drive images
# For GitHub Secrets: Store as IMAGE_CACHE_ENABLED
IMAGE_CACHE_ENABLED=true

# Cache duration in milliseconds (e.g., 300000 for 5 minutes)
# For GitHub Secrets: Store as IMAGE_CACHE_DURATION
IMAGE_CACHE_DURATION=300000

# Optional: Secret token for clearing cache via API
# For GitHub Secrets: Store as CACHE_CLEAR_SECRET
CACHE_CLEAR_SECRET=
